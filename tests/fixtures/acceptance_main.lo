var a = Complex(1,2)
var b = Complex(2,3)
var c = a.add(b)

var d = fibo(c.real)

struct Complex {
    real i32
    imag i32

    def add(a Complex) Complex {
        ret Complex(real = self.real + a.real, imag = self.imag + a.imag)
    }
}

def fibo(a i32) i32 {
    var b = 1
    if a < 2 {
        ret 1
    }

    ret fibo(a-1) + fibo(a-2)
}
